        echo "      " . $s['dir'] . "\n";
    }
    echo "\n\033[2mnew <name> · install <src> [--force] · export <name> [out] · remove <name>\033[0m\n";
    exit(0);
}

// Memory Command - graph knowledge base (list / new / show / search / graph / rm)
if ($argc >= 2 && $argv[1] === 'memory') {
