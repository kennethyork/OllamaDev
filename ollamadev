    $norm = [];
    foreach ($todos as $t) {
        if (!is_array($t)) continue;
        $content = trim((string)($t['content'] ?? $t['task'] ?? $t['text'] ?? ''));
        if ($content === '') continue;
        $status = (string)($t['status'] ?? 'pending');
        if (!in_array($status, ['pending', 'in_progress', 'completed'], true)) $status = 'pending';
