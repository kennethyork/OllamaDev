    if (in_array('--no-skills', $argv, true)) $copts['skills'] = false;
    foreach (['directorModel', 'coderModel', 'auditorModel', 'researcherModel'] as $rk) if (!empty($flags[$rk])) $copts[$rk] = $flags[$rk];
    if (!empty($flags['focus'])) $copts['focus'] = $flags['focus'];
