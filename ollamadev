        $expr = $p['expr'] ?? $p['expression'] ?? $p['calculation'] ?? $p['equation'] ?? $p['value'] ?? ($p[0] ?? '');
    } else { $expr = (string)$p; }
    if (empty($expr)) return "missing expression";
