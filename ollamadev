    $basePath = $p['path'] ?? $p['file_path'] ?? '.';
    if (strpos($pattern, '*') === false) $pattern = '**/*' . $pattern;
    $files = glob(rtrim($basePath, '/') . '/' . $pattern, GLOB_BRACE);
    if (empty($files)) return "No files found";
    $n = count($files); $files = array_slice($files, 0, 500);
    return implode("\n", $files) . ($n > 500 ? "\n…[{$n} matches; showing 500 — narrow the pattern]" : '');
});

