    $file = $p['file'] ?? '';
    $cached = $p['cached'] ?? false;
    $cmd = "cd " . escapeshellarg($path) . " && git diff";
    if ($cached) $cmd .= " --cached";
    if (!empty($file)) $cmd .= " -- " . escapeshellarg($file);
    return shell_exec($cmd . " 2>&1") ?: "No changes";
});

